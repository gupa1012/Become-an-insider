# ── Detection thresholds ───────────────────────────────────────────────────
# Periods of daily history used to compute rolling average volume (default: 20)
# VOLUME_LOOKBACK_PERIODS=20

# Volume multiple that triggers a spike alert (default: 3.0 = 3× avg volume)
# VOLUME_SPIKE_THRESHOLD=3.0

# Absolute % price change from session open that triggers a velocity alert
# PRICE_CHANGE_THRESHOLD_PCT=1.5

# Min number of different asset categories spiking at the same time to
# trigger a cross-asset coordination alert (default: 2)
# CROSS_ASSET_MIN_CATEGORIES=2

# ── Monitor loop ───────────────────────────────────────────────────────────
# How often (seconds) to scan all assets (default: 60)
# CHECK_INTERVAL_SECONDS=60

# Suppress repeat alerts for the same symbol+type for this many seconds
# ALERT_COOLDOWN_SECONDS=300

# ── Alert channels ─────────────────────────────────────────────────────────
# Console output is always on; set to false to silence it
# CONSOLE_ALERTS=true

# ── E-mail (SMTP) ──────────────────────────────────────────────────────────
# EMAIL_ENABLED=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=you@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_FROM=you@gmail.com
# EMAIL_TO=recipient@example.com

# ── Slack (Incoming Webhook) ────────────────────────────────────────────────
# SLACK_ENABLED=false
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ── Telegram Bot ────────────────────────────────────────────────────────────
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=987654321

# ── Discord (Incoming Webhook) ──────────────────────────────────────────────
# DISCORD_ENABLED=false
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
